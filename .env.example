# --- API (copy to apps/api/.env) ---
# SQLite for zero-setup local dev. For Postgres (docker compose up -d):
# DATABASE_URL="postgresql://arenafit:arenafit@localhost:5432/arenafit"
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# WebRTC groundwork (M2 human-vs-human video) — leave empty for STUN-only.
# Point at a coturn deployment (or managed TURN provider) once one exists.
TURN_URLS=""
TURN_USERNAME=""
TURN_CREDENTIAL=""

# --- Web (copy to apps/web/.env.local) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
