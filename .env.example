# --- API (copy to apps/api/.env) ---
# SQLite for zero-setup local dev. For Postgres (docker compose up -d):
# DATABASE_URL="postgresql://arenafit:arenafit@localhost:5432/arenafit"
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# --- Web (copy to apps/web/.env.local) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
